# =============================================
# Venta Uygulaması - Ortam Değişkenleri
# =============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# cp .env.example .env

# Firebase Konfigürasyonu
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Spotify OAuth Konfigürasyonu
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
# NOT: Client Secret artık sadece backend'de (api/spotify-token.js) kullanılır.
# Frontend'e asla eklemeyin!

# Spotify Token Exchange Endpoint
# Geliştirme: /api/spotify-token (Vite proxy)
# Production: https://vante.vercel.app/api/spotify-token
VITE_SPOTIFY_TOKEN_URL=/api/spotify-token

# Uygulama URL'si (yasal sayfalar için)
# Geliştirme: http://localhost:3000
# Production: https://vante.vercel.app
VITE_APP_URL=https://vante.vercel.app

# =============================================
# Spotify Redirect URI Ayarları
# =============================================
# Spotify Developer Dashboard'da şu redirect URI'leri kaydedin:
#
# Web (geliştirme):   http://localhost:3000/
# Web (production):   https://vante.vercel.app/
# Android (native):   com.vante.app://callback
# iOS (native):       com.vante.app://callback
#
# Native redirect URI AndroidManifest.xml'deki intent-filter ile eşleşmelidir.
# Uygulama kodu redirect URI'yi otomatik seçer:
#   - Capacitor native platformda: com.vante.app://callback
#   - Web platformda: window.location.origin + '/'
