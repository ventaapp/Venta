<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: Yalnızca HTTPS bağlantılarına izin ver -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Geliştirme ortamı için localhost'a HTTP izni (sadece debug build'de) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
